{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "packages/laravelcollective-html",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.2",
        "abraham/twitteroauth": "^7.0",
        "andreaselia/laravel-api-to-postman": "^2.3",
        "barryvdh/laravel-dompdf": "^3.0",
        "cartalyst/stripe-laravel": "^17.0",
        "ckeditor/ckeditor": "4.*",
        "diglactic/laravel-breadcrumbs": "^10.0",
        "doctrine/dbal": "^4.0",
        "genealabs/laravel-model-caching": "^13.0",
        "guzzlehttp/guzzle": "^7.8",
        "intervention/image": "^2.7",
        "laravel/framework": "^12.0",
        "laravel/helpers": "^1.7",
        "laravel/socialite": "^5.16",
        "laravel/tinker": "^2.10",
        "laravel/ui": "^4.6",
        "laravelcollective/html": "@dev",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1.69",
        "mews/purifier": "^3.4",
        "renatomarinho/laravel-page-speed": "^3.0",
        "silber/page-cache": "^1.1",
        "spatie/laravel-cookie-consent": "^3.3",
        "spatie/laravel-image-optimizer": "^1.8",
        "spatie/laravel-permission": "^6.0",
        "spatie/schema-org": "^3.14",
        "srmklive/paypal": "^3.0",
        "tymon/jwt-auth": "^2.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.14",
        "fakerphp/faker": "^1.23",
        "kitloong/laravel-migrations-generator": "^7.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.5.6"
        },
        "platform-check": false,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
